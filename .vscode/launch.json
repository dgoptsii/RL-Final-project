{
  "version": "0.2.0",
  "configurations": [

    // =========================
    // DDPG
    // =========================
    {
      "name": "DDPG - FetchReach Dense",
      "type": "debugpy",
      "request": "launch",
      "program": "baselines/baseline_ddpg.py",
      "args": [
        "--task", "FetchReach",
        "--reward-type", "dense",
        "--episodes", "500",
        "--seed", "0",
        "--device", "cpu",

        "--batch-size", "256",
        "--actor-lr", "0.0001",
        "--critic-lr", "0.001",
        "--gamma", "0.98",
        "--tau", "0.005",

        "--start-steps", "1000",
        "--action-noise", "0.1",

        "--eval-every", "10",
        "--eval-episodes", "20"
      ]
    },
